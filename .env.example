# ⚠️ ARQUIVO EXEMPLO - COPIAR PARA .env E PREENCHER COM VALORES REAIS
# NÃO COMMITAR .env EM GIT!

# Django Config
SECRET_KEY=seu-valor-aqui-gere-com-python-secrets
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,seu-dominio.com.br

# Database (SQLite padrão, mude em produção para PostgreSQL)
DATABASE_ENGINE=django.db.backends.sqlite3
DATABASE_NAME=db.sqlite3

# Email Config (opcional)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=seu-email@gmail.com
EMAIL_HOST_PASSWORD=sua-senha-app

# CORS - Origins permitidas
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://seu-dominio.com.br

# Rate Limiting Cache
CACHE_BACKEND=django.core.cache.backends.locmem.LocMemCache
