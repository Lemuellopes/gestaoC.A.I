# ════════════════════════════════════════════════
# C.A.I — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env no git!
# ════════════════════════════════════════════════

# ── Django Core ──────────────────────────────────
# Gere uma chave segura com:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=SUBSTITUA-POR-UMA-CHAVE-GERADA-ALEATORIAMENTE

# Em produção, defina como False
DJANGO_DEBUG=True

# Hosts permitidos (separados por vírgula)
ALLOWED_HOSTS=127.0.0.1,localhost

# Tema visual do admin (True = Jazzmin, False = Django admin padrão)
USE_JAZZMIN=False

# ── Banco de Dados (produção) ─────────────────────
# Para usar PostgreSQL em produção, instale psycopg2-binary
# e configure no settings.py
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=cai_db
# DB_USER=cai_user
# DB_PASSWORD=senha-segura
# DB_HOST=localhost
# DB_PORT=5432

# ── Segurança ─────────────────────────────────────
# Quantidade máxima de tentativas de login antes do bloqueio
LOGIN_MAX_ATTEMPTS=5
# Minutos de bloqueio após exceder tentativas
LOGIN_LOCKOUT_MINUTES=15
